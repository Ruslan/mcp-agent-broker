# Server port (default: 9197)
PORT=9197

# Data directory for tasks (default: data)
DATA_DIR=data

# Optional API key for authentication. 
# If set, clients must provide 'Authorization: Bearer <key>' header.
# API_KEY=your-secret-key-here

# Enable/disable sync tools (await_task, listen_role wait)
ENABLE_SYNC=true

# Enable/disable async tools (listen_role poll)
ENABLE_ASYNC=true
